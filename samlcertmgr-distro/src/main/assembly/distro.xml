<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <id>distro</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>samlcertmanager-${project.version}</baseDirectory>

    <dependencySets>
        <dependencySet>
            <includes>
                <include>${project.groupId}:samlcertmgr-backend</include>
            </includes>
            <outputDirectory>/</outputDirectory>
            <outputFileNameMapping>samlcertmgr.jar</outputFileNameMapping>
            <useProjectArtifact>false</useProjectArtifact>
        </dependencySet>
    </dependencySets>

    <fileSets>
        <fileSet>
            <!-- Actual location: samlcertmgr-backend/src/main/conf/config.yaml (not backend/config.yml). -->
            <directory>${project.basedir}/../samlcertmgr-backend/src/main/conf</directory>
            <includes>
                <include>config.yaml</include>
            </includes>
            <outputDirectory>/</outputDirectory>
        </fileSet>
        <fileSet>
            <!--
              Populated by the unpack-ui execution in this module's pom.xml
              (maven-dependency-plugin, prepare-package phase). Named "webapp"
              to match ScmServer's AssetsBundle("/webapp", ...) resource path —
              rename this (and the AssetsBundle call) to "ui" or "wwwroot" if
              IIS ends up serving these files directly rather than the JVM.
              Either way: if the JVM is meant to serve them, whatever launches
              the jar needs this directory added to the runtime classpath
              (e.g. a Class-Path entry in the manifest, or -cp on the command
              line) — a sibling directory on disk isn't on the classpath by
              default the way a bundled resource inside the jar would be.
            -->
            <directory>${project.build.directory}/assembled/ui</directory>
            <outputDirectory>/webapp</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/resources</directory>
            <outputDirectory>/</outputDirectory>
            <fileMode>0755</fileMode>
        </fileSet>
    </fileSets>
</assembly>